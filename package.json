{
  "name": "extaudit",
  "version": "0.1.0",
  "description": "Local-first CLI auditor for VSCode/Cursor extension manifests. Scan package.json files for suspicious permissions, network patterns, and security anomalies. Produces risk-scored JSON/Markdown reports.",
  "license": "MIT",
  "author": "Roger Chappel",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/extaudit.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/extaudit/issues"
  },
  "homepage": "https://github.com/rogerchappel/extaudit#readme",
  "keywords": [
    "vscode",
    "cursor",
    "extension",
    "audit",
    "security",
    "manifest",
    "cli",
    "supply-chain"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "extaudit": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dist": "node --test test/*.test.mjs",
    "smoke": "node dist/cli.js scan fixtures --format json",
    "package:smoke": "npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke",
    "fix": "echo 'No auto-fixer — review reports manually'"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.5",
    "tsx": "4.19.3",
    "typescript": "6.0.3",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "commander": "^12.1.0"
  }
}
