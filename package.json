{
  "name": "extaudit",
  "version": "0.1.0",
  "description": "Audit VSCode/Cursor extension manifests for suspicious permissions, network access patterns, and security anomalies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "extaudit": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "node --test --experimental-test-coverage 'tests/**/*.test.js'",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "smoke": "node dist/index.js scan fixtures/example-extensions/",
    "package:check": "npm pack --dry-run",
    "release:check": "npm test && npm run build && npm run package:check"
  },
  "keywords": [
    "vscode",
    "cursor",
    "extension",
    "security",
    "audit",
    "scanner",
    "supply-chain"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/extaudit.git"
  },
  "homepage": "https://github.com/rogerchappel/extaudit",
  "bugs": {
    "url": "https://github.com/rogerchappel/extaudit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.6.0"
  }
}
